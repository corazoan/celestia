model Admin {
  id           String  @id @default(cuid())
  firstName    String
  lastName     String
  email        String  @unique
  passwordHash String
  phoneNumber  String? @unique @db.VarChar(15)
  isActive     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admins")
}
